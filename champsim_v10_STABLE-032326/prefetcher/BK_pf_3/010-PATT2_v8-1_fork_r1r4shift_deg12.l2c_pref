// IDMM: MT2 MODULE ----------------------------------------------------------------------------------------------------------------------------        IDMM: MT2 MODULE
    vector<int64_t> markov_predictions2 = markov_prefetcher2.operate(shared_access_data);
    
    module_hit = false;
    for (int i = 0; i < pf_module_trackers[tracker_i].PF_HISTORY_SIZE; i++) {
        if (pf_module_trackers[tracker_i].pf_issue_history[i] == current_encoded) {
            module_hit = true;
            break;
        }
    }
    pf_module_trackers[tracker_i].operate(ip, alignedAddr, module_hit, empty_vector);
    
    if (DGB_ALWAYS_PF || (pf_module_trackers[tracker_i].get_pf_state(MSHR.SIZE, MSHR.occupancy) && !markov_predictions2.empty() ) ) {
        flagged = 0;
        pf_cnt = 0;
        for (auto offset : markov_predictions2) {
            if (flagged == 0){
                pf_guess_cnt[mt2_config.prefetcher_id]++;
                flagged = 1;
            }
            
            if (MSHR.occupancy < (MSHR.SIZE/2) ){   
                if (isPfActive[mt2_config.prefetcher_id]==true){ 
                        for (int i = 1; i <= MT_DEGREE; i++){
                            prefetcher_count[4]++;
                            currentRound_prefetches.push_back(make_pair(pf_addr, mt2_config.prefetcher_id));
                            pf_cnt++;

                            pf_addr = ((alignedAddr - (offset*i)) << LOG2_BLOCK_SIZE);
                            uint64_t pf_block = alignedAddr - (offset*i);
                            if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)){
                                if (PQ.occupancy < PQ.SIZE){
                                    prefetch_line(ip, addr, (pf_addr), FILL_L2, metadata_in);
                                    uint16_t encoded_pf = pf_module_trackers[tracker_i].encode_block(pf_block);
                                    pf_module_trackers[tracker_i].FIFO(encoded_pf);
                                }
                                else{
                                    prefetch_line(ip, addr, (pf_addr), FILL_LLC, metadata_in);
                                    uint16_t encoded_pf = pf_module_trackers[tracker_i].encode_block(pf_block);
                                    pf_module_trackers[tracker_i].FIFO(encoded_pf);
                                }
                            }
                        }
                }
                
            }
            else{
                if (isPfActive[mt2_config.prefetcher_id]==true){
                    prefetcher_count[4]++;
                    for (int i = 1; i <= MT_DEGREE; i++){
                        prefetcher_count[4]++;
                        currentRound_prefetches.push_back(make_pair(pf_addr, mt2_config.prefetcher_id));
                        pf_cnt++;
                        
                        pf_addr = ((alignedAddr - (offset*i)) << LOG2_BLOCK_SIZE);
                        uint64_t pf_block = alignedAddr - (offset*i);
                        if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)){
                            prefetch_line(ip, addr, (pf_addr), FILL_LLC, metadata_in);
                            uint16_t encoded_pf = pf_module_trackers[tracker_i].encode_block(pf_block);
                            pf_module_trackers[tracker_i].FIFO(encoded_pf);
                        }
                    }
                }
            }  
        }
    }
    
    tracker_avg_tracker[tracker_i] += pf_module_trackers[tracker_i].get_TotalHitRate();
    if (DBG_Pf_TRACKER_PRINT && cnt % TRACKER_STATS_PRINT_PERIOD == 0){
        cout << "MODULE TRACKER: " << setw(8) << tracker_i 
             << " WINDOW HIT RATE: " << setw(8) << fixed << setprecision(8) 
             << tracker_avg_tracker[tracker_i]/TRACKER_STATS_PRINT_PERIOD << " STATE: "<< setw(10) << pf_module_trackers[tracker_i].get_currentMask() << endl;
