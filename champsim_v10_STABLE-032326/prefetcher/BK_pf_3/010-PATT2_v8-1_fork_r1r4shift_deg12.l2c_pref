        trackers[i].lru = i;

    prefetcher_count[1]=0;
    prefetcher_count[2]=0;
    prefetcher_count[3]=0;
    prefetcher_count[4]=0;
    prefetcher_count[5]=0;
    prefetcher_count[6]=0;
    prefetcher_count[7]=0;
    prefetcher_count[8]=0;
    cout << "now  : DUMMY FLAG V11" << endl;
    isPfActive[1] = true;
    isPfActive[2] = true; 
    isPfActive[3] = true;
    isPfActive[4] = true;
}

#include <vector>
#include <stdexcept>
#include <cstdint>
struct track_module_hits {
    // Constants
    uint64_t ip;

    // static constexpr uint8_t PAGE_BITS = 16;
    // static constexpr uint8_t BLOCK_BITS = 6;
    // static constexpr uint8_t PF_HISTORY_SIZE = 64;
    // // static constexpr uint8_t PF_HIT_BITS = 16;  // 10 bits page + 6 bits block
    // static constexpr uint8_t WINDOW_SIZE = 4;   
    // static constexpr uint8_t NUM_ACCESSES_PER_WINDOW = 32;
    // static constexpr uint8_t BIT_LEN = 5; // MUST BE log 2 of NUM_ACCESSES_PER_WINDOW
    // static constexpr uint8_t MAX_INT_PACKED_LIMIT = (1 << BIT_LEN) - 1;  // 63
    // BEST ISH FOR GPT 256 TRACE 
    static constexpr uint8_t PAGE_BITS = 16;
    static constexpr uint8_t BLOCK_BITS = 6;
    static constexpr uint8_t PF_HISTORY_SIZE = 64;
    static constexpr uint8_t PF_HIT_BITS = 16;  // 10 bits page + 6 bits block
    static constexpr uint8_t WINDOW_SIZE =16;   
    static constexpr uint8_t NUM_ACCESSES_PER_WINDOW = 32;
    static constexpr uint8_t BIT_LEN = 5; // MUST BE log 2 of NUM_ACCESSES_PER_WINDOW
    static constexpr uint8_t MAX_INT_PACKED_LIMIT = (1 << BIT_LEN) - 1;  // 63
    
    // Configurable effectiveness level boundaries
    int8_t level_0_max = 0;   // Level 0: 0 to level_0_max hits
    int8_t level_1_max = 1;   // Level 1: (level_0_max+1) to level_1_max hits  
    int8_t level_2_max = 2;  // Level 2: (level_1_max+1) to level_2_max hits
    // Level 3: (level_2_max+1)+ hits
    
    // Data members
    uint32_t pf_issue_history[PF_HISTORY_SIZE];  // FIFO prefetch history
    uint8_t pf_write_ptr = 0;                    // FIFO write pointer
    uint8_t current_hit_count = 0;               // Hits in current window
    uint8_t access_counter = 0;                  // Accesses in current window  
    uint8_t window_history[WINDOW_SIZE];         // Window effectiveness history
    uint8_t window_ptr = 0;                      // Current window position
    bool module_active[PF_HISTORY_SIZE] = {true};

        
    // Configure effectiveness level boundaries for testing
    void set_effectiveness_levels(uint8_t max_0, uint8_t max_1, uint8_t max_2) {
        level_0_max = max_0;
        level_1_max = max_1; 
        level_2_max = max_2;
        // Level 3 is automatically anything above max_2
    }

    // FIXED: MSHR-aware prefetch decision - BOOTSTRAP ENABLED
    bool get_pf_state(int MSHR_SIZE, int MSHR_occupancy) {
        uint8_t current_mask = get_currentMask();
        uint8_t available_mshr = MSHR_SIZE - MSHR_occupancy;
        
        // FIXED: Allow bootstrapping with VERY_LOW effectiveness
        uint8_t required_threshold = 0;  // Default: allow VERY_LOW (0)
        if (available_mshr <= MSHR_SIZE/8) {
            required_threshold = 2;      // Need HIGH effectiveness
        } else if (available_mshr <= MSHR_SIZE/4) {
            required_threshold = 1;      // Need MEDIUM effectiveness
        } else if (available_mshr <= MSHR_SIZE) {
            required_threshold = 0;      // Need LOW effectiveness
        }
        
        return current_mask >= required_threshold;
    }
    
    // Shadow hit promotion - check for false negatives
    void shadow_hit_promotion(int encoded_access_block, bool hit) {
        if (hit){
            for (int i = 0; i < PF_HISTORY_SIZE; i++) {
                if (pf_issue_history[i] == encoded_access_block) {
                    if (window_history[window_ptr] == 0) {
                        window_history[window_ptr] = 1;  // Promote from VERY_LOW to LOW
                    }
                    break;
                }
            }
        }
    }

    // Main processing method
    void operate(uint64_t curr_ip, uint64_t block, bool hit, const std::vector<uint64_t>& issue_vector) {
        // Increment access counter
        ip=curr_ip;
        access_counter++;
        
        // Check for window boundary
        if (access_counter >= NUM_ACCESSES_PER_WINDOW) {
            // Encode current hit count into effectiveness using configurable boundaries
            uint8_t effectiveness = 0;
            if (current_hit_count <= level_0_max) {
                effectiveness = 0;  // Level 0
            } else if (current_hit_count <= level_1_max) {
                effectiveness = 1;  // Level 1
            } else if (current_hit_count <= level_2_max) {
                effectiveness = 2;  // Level 2
            } else {
                effectiveness = 3;  // Level 3
            }
            
            // Set the mask for current window
            setWindowMask(effectiveness);
            
            // Shift to next window and reset counters
            shiftWindow();
        }
        
        // FIRST: Check for shadow hit promotion
        int encodedAccessBlock = encode_block(block);
        shadow_hit_promotion(encodedAccessBlock, hit);
        
        // Process the current access
        if (hit) {
            for (int i = 0; i < PF_HISTORY_SIZE; i++) {
                if (pf_issue_history[i] == encodedAccessBlock) {
                    current_hit_count++;
                    break;
                }
            }
            
            if (current_hit_count > MAX_INT_PACKED_LIMIT) {
                throw std::runtime_error("[Pf ERROR] Pf module accuracy bit packing overflow occured line " + 
                                       std::to_string(__LINE__));
            }
        }
        
        // Add new prefetch issues
        addNewIssues(issue_vector);
    }
    
    // Add new prefetch issues to FIFO
    void addNewIssues(const std::vector<uint64_t>& issue_vector) {
        for (uint64_t block : issue_vector) {
            uint16_t encoded = encode_block(block);
            FIFO(encoded);
        }
    }
    
    // FIXED: Encode block for cache line addresses
    uint32_t encode_block(uint64_t block) {
        // For cache line addresses: 64 cache lines per 4KB page
        uint64_t page_number = block >> 6;  // FIXED: 6 bits for 64 cache lines
        
        static constexpr uint64_t fibonacci_multiplier = 11400714819323198486ULL;
        // uint64_t hash_result = page_number * fibonacci_multiplier;
        // uint64_t page_hash = (hash_result >> (64-PAGE_BITS));
        
        // uint64_t hash_result = page_number ^ ip ;
        uint64_t hash_result = (page_number >> 1) ^ (page_number >> 4)  ;
        // uint64_t page_hash = (hash_result >> (64-PAGE_BITS));
        uint64_t page_hash = hash_result & ((1ULL << PAGE_BITS) - 1);
        
        uint64_t max_page_value = (1ULL << PAGE_BITS) - 1;
        if (page_hash > max_page_value) {
            throw std::runtime_error("Page hash exceeds PAGE_BITS limit at line " + std::to_string(__LINE__));
        }
        // Block offset within page (6 bits)  
        uint64_t page_start = page_number << LOG2_BLOCK_SIZE;  // Page start address
        uint64_t block_offset = block - page_start;  // Offset within the page
        
        uint32_t combined = (page_hash << 6) | block_offset;
        constexpr uint32_t MAX_COMBINED = (1u << (PAGE_BITS + BLOCK_BITS)) - 1;
        if ((combined > MAX_COMBINED)) {
            throw std::overflow_error("Combined hash exceeds allocated bits");
        }
        return combined;
    }
    
    // O(1) FIFO insertion
    void FIFO(uint32_t encoded_block) {
        pf_issue_history[pf_write_ptr] = encoded_block;
        pf_write_ptr = (pf_write_ptr + 1) % PF_HISTORY_SIZE;
    }
    
    // Set mask value in window array
    void setWindowMask(uint8_t mask_value) {
        window_history[window_ptr] = mask_value;
    }
    
    // Shift to next window and reset counters
    void shiftWindow() {
        current_hit_count = 0;
        access_counter = 1;
        window_ptr = (window_ptr + 1) % WINDOW_SIZE;
    }
    
    // Get current window mask value
    int get_currentMask() {
        return window_history[window_ptr];
    }
    
    // Calculate total hit rate across all windows using configurable boundaries
    float get_TotalHitRate() {
        uint32_t total_estimated_hits = 0;
        uint32_t total_windows = 0;
        
        for (int i = 0; i < WINDOW_SIZE; i++) {
            uint8_t effectiveness = window_history[i];
            
            uint32_t estimated_hits = 0;
            if (effectiveness == 0) {
                estimated_hits = level_0_max;  // Conservative estimate for level 0 range
            } else if (effectiveness == 1) { 
                estimated_hits = (level_0_max + 1 + level_1_max);  // Midpoint of level 1 range
            } else if (effectiveness == 2) {
                estimated_hits = (level_1_max + 1 + level_2_max);  // Midpoint of level 2 range
            } else if (effectiveness == 3) {
                estimated_hits = level_2_max + 5;  // Conservative estimate for level 3 range
            }
            
            total_estimated_hits += estimated_hits;
            total_windows++;
        }
        
        if (total_windows == 0) return 0.0f;
        
        uint32_t total_accesses = total_windows * NUM_ACCESSES_PER_WINDOW;
        return (float)total_estimated_hits / total_accesses;
    }
};


track_module_hits pf_module_trackers[32];
double tracker_avg_tracker[32] = {0};
int tracker_i = 0;
bool module_hit = false;

uint32_t CACHE::l2c_prefetcher_operate(uint64_t addr, uint64_t ip, uint8_t cache_hit, uint8_t type, uint32_t metadata_in) {
    // Cache hit tracking - EXACT as original
    if (cache_hit) {
        for (auto it = currentRound_prefetches.begin(); it != currentRound_prefetches.end(); ++it) {
            if (it->first == (addr >> LOG2_BLOCK_SIZE << LOG2_BLOCK_SIZE)) {
                nxtH_cnt[it->second]++;
            }
        }
        tH_cnt++;
    }
    currentRound_prefetches.clear();

    // IP stride average tracking - EXACT as original
    // nxtAddrHit_IP_Stride_avg = (nxtAddrHit_IP_Stride_avg*nxtAddrHit_IP_Stride_avg_cnt + pf_nxtH_acc[0])/(++nxtAddrHit_IP_Stride_avg_cnt);
    
    // // Cache initialization - EXACT as original
    if(NUM_CACHELINES == 0){
        uint64_t cache_size = (L2C_SET*L2C_WAY*BLOCK_SIZE)/1024;
        cout << "CPU " << cpu << " L2C prefetcher initialized" << endl;
        cout << "\n\nCache Size: " << cache_size << endl;
        cout << "number of cache lines: " << L2C_SET*L2C_WAY << endl;
        NUM_CACHELINES = L2C_SET*L2C_WAY;
    }
    
    uint64_t alignedAddr = addr >> LOG2_BLOCK_SIZE;
    shared_access_data.init_process_access(alignedAddr, ip); 
    uint16_t current_encoded = pf_module_trackers[0].encode_block(alignedAddr);
    // NEW IDMM REQUIRES:
        // 1. NEW GLOBAL IDMM OBJECT
        // 2. NEW CONFIG OF NEW OBJ INSIDE Pf INITIALIZE 
        // 3. SET CONFIG FOR IDMM OBJECT AT END OF Pf INITIALIZE

 
    // PRE PROCESSING DONE!!! 

// MARKOV IP STRIDE PREFETCHER ------------------------------------------------------------------------------------------------------------             MARKOV IP STRIDE PREFETCHER

    vector<int64_t> stride_predictions = markov_ip_stride.operate(shared_access_data);
    
    module_hit = false;
    for (int i = 0; i < pf_module_trackers[tracker_i].PF_HISTORY_SIZE; i++) {
        if (pf_module_trackers[tracker_i].pf_issue_history[i] == current_encoded) {
            module_hit = true;
            break;
        }
    }
    
    vector<uint64_t> empty_vector;
    pf_module_trackers[tracker_i].operate(ip, alignedAddr, module_hit, empty_vector);
    
    if (DGB_ALWAYS_PF || (pf_module_trackers[tracker_i].get_pf_state(MSHR.SIZE, MSHR.occupancy) && !stride_predictions.empty())) {
        for (auto stride : stride_predictions) {
            if (stride == 0) continue;
            
            int prefetchDegree;
            if (MSHR.occupancy < (1*MSHR.SIZE)/8)
                prefetchDegree = PREFETCH_DEGREE;
            else if (MSHR.occupancy < (1*MSHR.SIZE)/5)
                prefetchDegree = PREFETCH_DEGREE/2;
            else if (MSHR.occupancy < (1*MSHR.SIZE)/2)
                prefetchDegree = PREFETCH_DEGREE/5;
            else 
                prefetchDegree = PREFETCH_DEGREE/4;

            if (pf_nxtH_acc[0]-nxtAddrHit_IP_Stride_avg>0.05){
                prefetchDegree +=4;
            }

            flagged = 0;
            for (int i=0; i<prefetchDegree; i++) {
                if (flagged == 0){
                    pf_guess_cnt[IPSTR_ID]++;
                    flagged = 1;
                }

                uint64_t pf_addr = (alignedAddr + (stride*(i+1))) << LOG2_BLOCK_SIZE;
                uint64_t pf_block = alignedAddr + (stride*(i+1));
                metadata_in = 1; 
                
                if (MSHR.occupancy < ((MSHR.SIZE/4)*3) || pf_nxtH_acc[IPSTR_ID] > 0.01){
                    prefetch_line(ip, addr, pf_addr, FILL_L2, metadata_in);
                    uint16_t encoded_pf = pf_module_trackers[tracker_i].encode_block(pf_block);
                    pf_module_trackers[tracker_i].FIFO(encoded_pf);
                }
                else{
                    prefetch_line(ip, addr, pf_addr, FILL_LLC, metadata_in);
                    uint16_t encoded_pf = pf_module_trackers[tracker_i].encode_block(pf_block);
                    pf_module_trackers[tracker_i].FIFO(encoded_pf);
                }
                metadata_in = 0;
                currentRound_prefetches.push_back(make_pair(pf_addr, IPSTR_ID));
                prefetcher_count[2]++;
            }
        }
    }
    
    tracker_avg_tracker[tracker_i] += pf_module_trackers[tracker_i].get_TotalHitRate();
    if (DBG_Pf_TRACKER_PRINT && cnt % TRACKER_STATS_PRINT_PERIOD == 0){
        cout << "MODULE TRACKER: " << setw(8) << tracker_i 
             << " WINDOW HIT RATE: " << setw(8) << fixed << setprecision(8) 
             << tracker_avg_tracker[tracker_i]/TRACKER_STATS_PRINT_PERIOD << " STATE: "<< setw(10) << pf_module_trackers[tracker_i].get_currentMask() << endl;
        tracker_avg_tracker[tracker_i] = 0; 
    }
    tracker_i++;

// MARKOV IP STRIDE PREFETCHER ------------------------------------------------------------------------------------------------------------             MARKOV IP STRIDE PREFETCHER

// IDMM: MT1 MODULE ----------------------------------------------------------------------------------------------------------------------------        IDMM: MT1 MODULE    
    pf_cnt = 0;
    vector<int64_t> markov_predictions1 = markov_prefetcher1.operate(shared_access_data);
    
    module_hit = false;
    for (int i = 0; i < pf_module_trackers[tracker_i].PF_HISTORY_SIZE; i++) {
        if (pf_module_trackers[tracker_i].pf_issue_history[i] == current_encoded) {
            module_hit = true;
            break;
        }
    }
    pf_module_trackers[tracker_i].operate(ip, alignedAddr, module_hit, empty_vector);
    
    if (DGB_ALWAYS_PF || (pf_module_trackers[tracker_i].get_pf_state(MSHR.SIZE, MSHR.occupancy) && !markov_predictions1.empty() ) ) {
        flagged = 0;
        for (auto offset : markov_predictions1) {
            if (flagged == 0){
                pf_guess_cnt[mt1_config.prefetcher_id]++;
                flagged = 1;
            }
            
            if (MSHR.occupancy < (MSHR.SIZE/2)){    
                if (isPfActive[mt1_config.prefetcher_id]==true){
                    for (int i = 1; i <= MT_DEGREE; i++){
                        
                        prefetcher_count[3]++;
                        currentRound_prefetches.push_back(make_pair(pf_addr, mt1_config.prefetcher_id));
                        pf_cnt++;

                        pf_addr = ((alignedAddr - (offset*i)) << LOG2_BLOCK_SIZE);
                        uint64_t pf_block = alignedAddr - (offset*i);
                        if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)){
                            if (PQ.occupancy < PQ.SIZE){
                                prefetch_line(ip, addr, (pf_addr), FILL_L2, metadata_in);
                                uint16_t encoded_pf = pf_module_trackers[tracker_i].encode_block(pf_block);
                                pf_module_trackers[tracker_i].FIFO(encoded_pf);
                            }
                            else{
                                prefetch_line(ip, addr, (pf_addr), FILL_LLC, metadata_in);
                                uint16_t encoded_pf = pf_module_trackers[tracker_i].encode_block(pf_block);
                                pf_module_trackers[tracker_i].FIFO(encoded_pf);
                            }
                        }
                    }
                }
                currentRound_prefetches.push_back(make_pair(pf_addr, mt1_config.prefetcher_id));
            }
            else{
                if (isPfActive[mt1_config.prefetcher_id]==true){
                    for (int i = 1; i <= MT_DEGREE; i++){
                        prefetcher_count[3]++;
                        currentRound_prefetches.push_back(make_pair(pf_addr, mt1_config.prefetcher_id));
                        pf_cnt++;
                        
                        pf_addr = ((alignedAddr - (offset*i)) << LOG2_BLOCK_SIZE);
                        uint64_t pf_block = alignedAddr - (offset*i);
                        if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)){
                            prefetch_line(ip, addr, (pf_addr), FILL_LLC, metadata_in);
                            uint16_t encoded_pf = pf_module_trackers[tracker_i].encode_block(pf_block);
                            pf_module_trackers[tracker_i].FIFO(encoded_pf);
                        }
                    }
                }
                
            }  
        }
    }
    
    tracker_avg_tracker[tracker_i] += pf_module_trackers[tracker_i].get_TotalHitRate();
    if (DBG_Pf_TRACKER_PRINT && cnt % TRACKER_STATS_PRINT_PERIOD == 0){
        cout << "MODULE TRACKER: " << setw(8) << tracker_i 
             << " WINDOW HIT RATE: " << setw(8) << fixed << setprecision(8) 
             << tracker_avg_tracker[tracker_i]/TRACKER_STATS_PRINT_PERIOD << " STATE: "<< setw(10) << pf_module_trackers[tracker_i].get_currentMask() << endl;
        tracker_avg_tracker[tracker_i] = 0; 
    }
