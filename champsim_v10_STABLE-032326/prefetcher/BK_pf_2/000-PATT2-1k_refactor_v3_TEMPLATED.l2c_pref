    mt1_config.tracking_key="ip"; mt1_config.tracking_value="delta_block";
    
    mt2_config.lru_size=128; mt2_config.tracking_max=32; mt2_config.tracking_min=16; mt2_config.percent_threshold=30; mt2_config.prefetcher_id=2;
    mt2_config.tracking_key="ip"; mt2_config.tracking_value="delta_block";
    
    mt3_config.lru_size=320; mt3_config.tracking_max=16; mt3_config.tracking_min=8; mt3_config.percent_threshold=25; mt3_config.prefetcher_id=3;
    mt3_config.tracking_key="ip"; mt3_config.tracking_value="delta_block";
    
    mt4_config.lru_size=512; mt4_config.tracking_max=8; mt4_config.tracking_min=1; mt4_config.percent_threshold=20; mt4_config.prefetcher_id=4;
    mt4_config.tracking_key="ip"; mt4_config.tracking_value="delta_block";

    mt5_config.lru_size=128; mt5_config.tracking_max=64; mt5_config.tracking_min=1; mt5_config.percent_threshold=50; mt5_config.prefetcher_id=5;
    mt5_config.tracking_key="delta_ip"; mt5_config.tracking_value="delta_ip";

    markov_prefetcher1.set_config(&mt1_config);
    markov_prefetcher2.set_config(&mt2_config);
    markov_prefetcher3.set_config(&mt3_config);
    markov_prefetcher4.set_config(&mt4_config);
    markov_prefetcher5.set_config(&mt5_config);

    cout << "MT1: " << "Size: " << mt1_config.lru_size << " TMAX: " << mt1_config.tracking_max << " TMIN: " << mt1_config.tracking_min << " MT1PTHRESH: " << mt1_config.percent_threshold << endl;
    cout << "MT2: " << "Size: " << mt2_config.lru_size << " TMAX: " << mt2_config.tracking_max << " TMIN: " << mt2_config.tracking_min << " MT2PTHRESH: " << mt2_config.percent_threshold << endl;
    cout << "MT3: " << "Size: " << mt3_config.lru_size << " TMAX: " << mt3_config.tracking_max << " TMIN: " << mt3_config.tracking_min << " MT3PTHRESH: " << mt3_config.percent_threshold << endl;
    cout << "MT4: " << "Size: " << mt4_config.lru_size << " TMAX: " << mt4_config.tracking_max << " TMIN: " << mt4_config.tracking_min << " MT4PTHRESH: " << mt4_config.percent_threshold << endl;

    cout << "Stride Size: " << IP_TRACKER_COUNT << " Prefetch Degree: " << PREFETCH_DEGREE << endl<< endl; 
    cout << "CPU " << cpu << " L2C prefetcher" << endl;
    
    for (int i=0; i<IP_TRACKER_COUNT; i++)
        trackers[i].lru = i;

    prefetcher_count[1]=0;
    prefetcher_count[2]=0;
    prefetcher_count[3]=0;
    prefetcher_count[4]=0;
    prefetcher_count[5]=0;
    prefetcher_count[6]=0;
    prefetcher_count[7]=0;
    prefetcher_count[8]=0;
    cout << "now  : DUMMY FLAG V11" << endl;
    isPfActive[1] = true;
    isPfActive[2] = true; 
    isPfActive[3] = true;
    isPfActive[4] = true;
}

