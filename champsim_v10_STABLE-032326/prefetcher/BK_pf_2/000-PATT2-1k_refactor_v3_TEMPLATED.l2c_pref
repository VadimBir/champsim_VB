                    if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)){
                        if (PQ.occupancy < PQ.SIZE){
                            prefetch_line(ip, addr, (pf_addr), FILL_L2, metadata_in);
                        }
                        else{
                            // cout << "PQ: " << PQ.occupancy << " " << PQ.SIZE << " " << endl;
                            prefetch_line(ip, addr, (pf_addr), FILL_LLC, metadata_in);
                            // cout << "LLC FILL" << endl;
                        }                        // cout << "PQ: " << PQ.occupancy << " " << MSHR.occupancy << " " << endl;
                    }
                }
            }
            currentRound_prefetches.push_back(make_pair(pf_addr, mt1_config.prefetcher_id));
        }
        else{
            if (isPfActive[mt1_config.prefetcher_id]==true){
                for (int i = 1; i < MT_DEGREE; i++){
                    pf_addr = ((alignedAddr - (offset*i)) << LOG2_BLOCK_SIZE);
                    if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)){
                        prefetch_line(ip, addr, (pf_addr), FILL_LLC, metadata_in);
                    }
                }
            }
            currentRound_prefetches.push_back(make_pair(pf_addr, mt1_config.prefetcher_id));
        }  
        prefetcher_count[3]++;
        pf_cnt++;
    }

    // mt2
    vector<int64_t> markov_predictions2 = markov_prefetcher2.operate(shared_access_data, alignedAddr, ip, cache_hit, type);
    flagged = 0;
    pf_cnt = 0;
    for (auto offset : markov_predictions2) {
        if (flagged == 0){
            pf_guess_cnt[mt2_config.prefetcher_id]++;
            flagged = 1;
        }
        
        if (pf_nxtH_acc[mt2_config.prefetcher_id] < 0.01 && pf_cnt >= 3){
            continue;
        }
        if (pf_nxtH_acc[mt2_config.prefetcher_id]<0.001 && pf_cnt >= 1){
            continue;
        }
        
        if (MSHR.occupancy < (MSHR.SIZE/2) ){   
            if (isPfActive[mt2_config.prefetcher_id]==true){ 
                    for (int i = 1; i < MT_DEGREE; i++){
                        pf_addr = ((alignedAddr - (offset*i)) << LOG2_BLOCK_SIZE);
                        if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)){
                            if (PQ.occupancy < PQ.SIZE){
                                prefetch_line(ip, addr, (pf_addr), FILL_L2, metadata_in);
                            }
                            else{
                                prefetch_line(ip, addr, (pf_addr), FILL_LLC, metadata_in);
                                // cout << "LLC FILL" << endl;
                            }
                        }
                    }
            }
            prefetcher_count[4]++;
            currentRound_prefetches.push_back(make_pair(pf_addr, mt2_config.prefetcher_id));
        }
        else{
            if (isPfActive[mt2_config.prefetcher_id]==true){
                prefetcher_count[4]++;
                for (int i = 1; i < MT_DEGREE; i++){
                    pf_addr = ((alignedAddr - (offset*i)) << LOG2_BLOCK_SIZE);
                    if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)){
                        prefetch_line(ip, addr, (pf_addr), FILL_LLC, metadata_in);
                    }
                }
            }
        }
        pf_cnt++;  
    }

    // mt3
    pf_cnt = 0;
    vector<int64_t> markov_predictions3 = markov_prefetcher3.operate(shared_access_data, alignedAddr, ip, cache_hit, type);
    flagged = 0;
    for (auto offset : markov_predictions3) {
        if (flagged == 0){
            pf_guess_cnt[mt3_config.prefetcher_id]++;
            flagged = 1;
        }

        if (pf_nxtH_acc[mt3_config.prefetcher_id] < 0.01 && pf_cnt >= 3){
            continue;
        }
if (pf_nxtH_acc[mt3_config.prefetcher_id]<0.001 && pf_cnt >= 1){
           continue;
       }


       if (MSHR.occupancy < (MSHR.SIZE/2)){  
           if (isPfActive[mt3_config.prefetcher_id]==true){
                for (int i = 1; i < MT_DEGREE; i++){
                    pf_addr = ((alignedAddr - (offset*i)) << LOG2_BLOCK_SIZE);
                    if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)){
                        if (PQ.occupancy < PQ.SIZE){
                            prefetch_line(ip, addr, (pf_addr), FILL_L2, metadata_in);
                        }
                        else{
                            prefetch_line(ip, addr, (pf_addr), FILL_LLC, metadata_in);
                            // cout << "LLC FILL" << endl;
                        }
                    }
                }
           }  
           prefetcher_count[5]++;
           currentRound_prefetches.push_back(make_pair(pf_addr, mt3_config.prefetcher_id));
       }
       else{
           if (isPfActive[mt3_config.prefetcher_id]==true){
           prefetcher_count[5]++;
            for (int i = 1; i < MT_DEGREE; i++){
                pf_addr = ((alignedAddr - (offset*i)) << LOG2_BLOCK_SIZE);
                if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)){
                        prefetch_line(ip, addr, (pf_addr), FILL_LLC, metadata_in);
                }
            }
           }
       }  
       pf_cnt++;
   }

   // mt4
   vector<int64_t> markov_predictions4 = markov_prefetcher4.operate(shared_access_data, alignedAddr, ip, cache_hit, type);
   flagged = 0;
   pf_cnt = 0;
   for (auto offset : markov_predictions4) {
       if (flagged == 0){
           pf_guess_cnt[mt4_config.prefetcher_id]++;
           flagged = 1;
       }

       if (pf_nxtH_acc[mt4_config.prefetcher_id] < 0.01 && pf_cnt >= 3){
           continue;
       }
       if (pf_nxtH_acc[mt4_config.prefetcher_id]<0.001 && pf_cnt >= 1){
           continue;
       }
       

       
       if (MSHR.occupancy < (MSHR.SIZE/2)){ 
           if (isPfActive[mt4_config.prefetcher_id]==true){
                for (int i = 1; i < MT_DEGREE; i++){
                    pf_addr = ((alignedAddr - (offset*i)) << LOG2_BLOCK_SIZE);
                    if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)){
                        if (PQ.occupancy < PQ.SIZE){
                            prefetch_line(ip, addr, (pf_addr), FILL_L2, metadata_in);
                        }
                        else{
                            prefetch_line(ip, addr, (pf_addr), FILL_LLC, metadata_in);
                            // cout << "LLC FILL" << endl;
                        }
                    }
                }
           }   
           prefetcher_count[6]++;
           currentRound_prefetches.push_back(make_pair(pf_addr, mt4_config.prefetcher_id));
       }
       else{
           if (isPfActive[mt4_config.prefetcher_id]==true){
               for (int i = 1; i < MT_DEGREE; i++){
                    pf_addr = ((alignedAddr - (offset*i)) << LOG2_BLOCK_SIZE);
                    if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)){
                        prefetch_line(ip, addr, (pf_addr), FILL_LLC, metadata_in);
                    }
               }
               prefetcher_count[6]++;
           }
       }  
   }

   // mt5 - IP Delta Predictor
    // vector<int64_t> markov_predictions5 = markov_prefetcher5.operate(shared_access_data, alignedAddr, ip, cache_hit, type);
    flagged = 0;
    pf_cnt = 0;
    // cout << "MT5: " << markov_predictions5.size();
    // current ip 
    // cout << "IP: " << ip ;

        // cout << " " << ip-offset;
        // PREDICTIONS FOR NEXT IPS FROM markov_predictions1 to markov_predictions4 
    // mt5 - IP Delta Predictor  
    vector<int64_t> markov_predictions5 = markov_prefetcher5.operate(shared_access_data, alignedAddr, ip, cache_hit, type);

    // For each predicted IP, query the spatial prefetchers without corrupting their state
    for (auto offset : markov_predictions5) {
        uint64_t predicted_ip = ip - offset;
        
        // Query each spatial prefetcher with the predicted IP
        vector<int64_t> spatial_predictions1 = markov_prefetcher1.query_predictions(predicted_ip);
        vector<int64_t> spatial_predictions2 = markov_prefetcher2.query_predictions(predicted_ip);
        vector<int64_t> spatial_predictions3 = markov_prefetcher3.query_predictions(predicted_ip);
        vector<int64_t> spatial_predictions4 = markov_prefetcher4.query_predictions(predicted_ip);
        
        // Process all spatial predictions
        for (auto spatial_offset : spatial_predictions1) {
            pf_addr = ((alignedAddr - spatial_offset) << LOG2_BLOCK_SIZE);
            if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)) {
                if (PQ.occupancy < PQ.SIZE) {
                    prefetch_line(ip, addr, pf_addr, FILL_L2, metadata_in);
                } else {
                    prefetch_line(ip, addr, pf_addr, FILL_LLC, metadata_in);
                }
            }
        }
        // Repeat for spatial_predictions2, 3, and 4...
        for (auto spatial_offset : spatial_predictions2) {
            pf_addr = ((alignedAddr - spatial_offset) << LOG2_BLOCK_SIZE);
            if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)) {
                if (PQ.occupancy < PQ.SIZE) {
                    prefetch_line(ip, addr, pf_addr, FILL_L2, metadata_in);
                } else {
                    prefetch_line(ip, addr, pf_addr, FILL_LLC, metadata_in);
                }
            }
        }
        for (auto spatial_offset : spatial_predictions3) {
            pf_addr = ((alignedAddr - spatial_offset) << LOG2_BLOCK_SIZE);
            if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)) {
                if (PQ.occupancy < PQ.SIZE) {
                    prefetch_line(ip, addr, pf_addr, FILL_L2, metadata_in);
                } else {
                    prefetch_line(ip, addr, pf_addr, FILL_LLC, metadata_in);
                }
            }
        }
        for (auto spatial_offset : spatial_predictions4) {
            pf_addr = ((alignedAddr - spatial_offset) << LOG2_BLOCK_SIZE);
            if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)) {
                if (PQ.occupancy < PQ.SIZE) {
                    prefetch_line(ip, addr, pf_addr, FILL_L2, metadata_in);
                } else {
                    prefetch_line(ip, addr, pf_addr, FILL_LLC, metadata_in);
                }
            }
        }
    }

    // cout << endl << "Acc: " << pf_nxtH_acc[mt5_config.prefetcher_id] << endl;

    // for (auto offset : markov_predictions5) {
    //     if (flagged == 0){
    //         pf_guess_cnt[mt5_config.prefetcher_id]++;
    //         flagged = 1;
    //     }

    //     // Apply confidence filters like your other MTs
    //     if (pf_nxtH_acc[mt5_config.prefetcher_id] < 0.01 && pf_cnt >= 3){
    //         continue;
    //     }
    //     if (pf_nxtH_acc[mt5_config.prefetcher_id]<0.001 && pf_cnt >= 1){
    //         continue;
    //     }
        
    //     // Generate prefetch addresses using IP delta as spatial offset
    //     // Note: This interprets IP deltas as memory offsets, which is unconventional
    //     if (MSHR.occupancy < (MSHR.SIZE/2)){ 
    //         if (isPfActive[mt5_config.prefetcher_id]==true){
    //             for (int i = 1; i < MT_DEGREE; i++){
    //                 pf_addr = ((alignedAddr - (offset*i)) << LOG2_BLOCK_SIZE);
    //                 if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)){
    //                     if (PQ.occupancy != PQ.SIZE){
    //                         // prefetch_line(ip, addr, (pf_addr), FILL_L2, metadata_in);
    //                     }
    //                     else{
    //                         // prefetch_line(ip, addr, (pf_addr), FILL_LLC, metadata_in);
    //                     }
    //                 }
    //             }
    //         }   
    //         prefetcher_count[mt5_config.prefetcher_id]++;  // Using index 7 for MT5
    //         currentRound_prefetches.push_back(make_pair(pf_addr, mt5_config.prefetcher_id));
    //     }
    //     else{
    //         if (isPfActive[mt5_config.prefetcher_id]==true){
    //             for (int i = 1; i < MT_DEGREE; i++){
    //                 pf_addr = ((alignedAddr - (offset*i)) << LOG2_BLOCK_SIZE);
    //                 if ((pf_addr >> LOG2_PAGE_SIZE) == (addr >> LOG2_PAGE_SIZE)){
    //                     // prefetch_line(ip, addr, (pf_addr), FILL_LLC, metadata_in);
    //                 }
    //             }
    //             prefetcher_count[mt5_config.prefetcher_id]++;
    //         }
    //     }  
    //     pf_cnt++;
    // }

   
   

   // Update global state - EXACT as original
   pre_previous_addr = previous_addr;
   preIP = ip;
   previous_addr = addr;
   cnt++;

   return metadata_in;
}

uint32_t CACHE::l2c_prefetcher_cache_fill(uint64_t addr, uint32_t set, uint32_t way, uint8_t prefetch, uint64_t evicted_addr, uint32_t metadata_in) {
   return metadata_in;
}

void CACHE::l2c_prefetcher_final_stats() {
   cout << "CPU " << cpu << " L2C PC-based stride prefetcher final stats" << endl;
   cout << "Stride Degree: " << PREFETCH_DEGREE << endl;
   
   cout << "MT1  MARKOV_LRU_SIZE: " << mt1_config.lru_size << endl;
   cout << "MT1  MARKOV_PREDICTION_PERCENTTHRESHOLD: " << mt1_config.percent_threshold << endl;
   cout << "MT1  OUTLIERS_THRESHOLD_Max: " << mt1_config.tracking_max << endl;
   cout << "MT1  OUTLIERS_THRESHOLD_Min: " << mt1_config.tracking_min << endl; 

   cout << "MT2  MARKOV_LRU_SIZE: " << mt2_config.lru_size << endl;
   cout << "MT2  MARKOV_PREDICTION_PERCENTTHRESHOLD: " << mt2_config.percent_threshold << endl;
   cout << "MT2  OUTLIERS_THRESHOLD_Max: " << mt2_config.tracking_max << endl;
   cout << "MT2  OUTLIERS_THRESHOLD_Min: " << mt2_config.tracking_min << endl; 

   cout << "MT3  MARKOV_LRU_SIZE: " << mt3_config.lru_size << endl;
   cout << "MT3  MARKOV_PREDICTION_PERCENTTHRESHOLD: " << mt3_config.percent_threshold << endl;
   cout << "MT3  OUTLIERS_THRESHOLD_Max: " << mt3_config.tracking_max << endl;
   cout << "MT3  OUTLIERS_THRESHOLD_Min: " << mt3_config.tracking_min << endl; 

   cout << "MT4  MARKOV_LRU_SIZE: " << mt4_config.lru_size << endl;
   cout << "MT4  MARKOV_PREDICTION_PERCENTTHRESHOLD: " << mt4_config.percent_threshold << endl;
   cout << "MT4  OUTLIERS_THRESHOLD_Max: " << mt4_config.tracking_max << endl;
   cout << "MT4  OUTLIERS_THRESHOLD_Min: " << mt4_config.tracking_min << endl;

   cout << "IPStride Degree/Access Ratio: " << (double)prefetcher_count[2]/(double)cnt << endl;
   cout << "MT1 IPDEltaMarkov  Degree/Access Ratio: " << (double)prefetcher_count[3]/(double)cnt << endl;
   cout << "MT2 IPDEltaMarkov  Degree/Access Ratio: " << (double)prefetcher_count[4]/(double)cnt << endl;
   cout << "MT3 IPDEltaMarkov  Degree/Access Ratio: " << (double)prefetcher_count[5]/(double)cnt << endl;
   cout << "MT4 IPDEltaMarkov  Degree/Access Ratio: " << (double)prefetcher_count[6]/(double)cnt << endl;
}