// Forward declaration for templated methods
struct AccessData;

// Templated access data structure with type-flexible extraction
struct AccessData {
    uint64_t addr;
    uint64_t ip;
    uint64_t block;
    uint64_t page;
    int64_t block2page;
    int64_t delta_ip;
    int64_t delta_page;
    int64_t delta_block;
    bool is_filled = false;
    
    AccessData() : addr(0), ip(0), block(0), page(0), block2page(0) {}
    
    void init_process_access(uint64_t new_addr, uint64_t new_ip) {
        addr = new_addr;
        ip = new_ip;
        block = addr; 
        page = addr >> 12;
        uint64_t page_start_block = page << (12 - LOG2_BLOCK_SIZE);
        block2page = block - page_start_block;
        is_filled = true;
    }
    
    // Template method declarations
    template<typename T>
    T get_key(const string& name, AccessData& prev_access_data) const;
    
    template<typename T>
    T get_value(const string& name, AccessData& prev_access_data) const;
};

// Template specializations for int64_t - PRESERVES EXACT ORIGINAL BEHAVIOR
template<>
int64_t AccessData::get_key<int64_t>(const string& name, AccessData& prev_access_data) const {
    if (name == "addr") return addr;
    if (name == "block") return block;
    if (name == "block2page") return block2page;
    if (name == "ip") return ip;
    if (name == "delta_ip") return (int64_t)(prev_access_data.ip)-(int64_t)(ip);
    if (name == "pre_delta_ip") return (int64_t)(prev_access_data.delta_ip); 
    if (name == "page") return page;
    if (name == "delta_page") return (int64_t)(prev_access_data.page)-(int64_t)(page);
    return 0;
}

template<>
int64_t AccessData::get_value<int64_t>(const string& name, AccessData& prev_access_data) const {
    if (name == "addr") return addr;
    if (name == "block2page") return block2page;
    if (name == "block") return block;
    if (name == "delta_block") return (int64_t)(prev_access_data.block)-(int64_t)(block);
    if (name == "delta_ip") return (int64_t)(prev_access_data.ip)-(int64_t)(ip);
    return 0;
}

// Example specialization for pair types (demonstrates flexibility)
template<>
pair<uint64_t, int64_t> AccessData::get_key<pair<uint64_t, int64_t>>(const string& name, AccessData& prev_access_data) const {
    if (name == "ip_delta_ip") return make_pair(ip, (int64_t)(prev_access_data.ip)-(int64_t)(ip));
    if (name == "addr_delta_block") return make_pair(addr, (int64_t)(prev_access_data.block)-(int64_t)(block));
    return make_pair(0, 0);
}

// Single shared AccessData instance
AccessData shared_access_data;

// Config struct - unchanged
struct MT_Config {
    int lru_size = 0;
    int tracking_max = 0; 
    int tracking_min = 0;
    int percent_threshold = 0;
    int prefetcher_id = 0;
    string tracking_key = "ip";
    string tracking_value = "delta_block";
};

// Config instances
MT_Config mt1_config, mt2_config, mt3_config, mt4_config, mt5_config, mt6_config, mt7_config, mt8_config;

// Templated IDMM class with backward-compatible defaults
template<typename KeyType = int64_t, typename ValueType = int64_t>
class IDMM {
public:
    AccessData prev_access_data;
    KeyType training_key;
    ValueType training_value;
    KeyType prediction_key;
    
    IDMM() : markov_LRU_front(0), pf_addr(0), config_ptr(nullptr), MT_limit(0) {}
    
    void set_config(const MT_Config* cfg) {
        config_ptr = cfg;
        MT_limit = cfg->lru_size;
        markov_LRU.clear();
        markov_LRU.reserve(MT_limit);
    }

    vector<ValueType> operate(const AccessData& access_data, uint64_t addr, uint64_t ip, uint8_t cache_hit, uint8_t type) {
        // Extract keys and values using templated methods
        prediction_key = access_data.get_key<KeyType>(config_ptr->tracking_key, prev_access_data);
        training_key = prev_access_data.get_key<KeyType>(config_ptr->tracking_key, prev_access_data);
        training_value = access_data.get_value<ValueType>(config_ptr->tracking_value, prev_access_data);
        
        // Update markov table - identical logic, templated types
        IteratorType key_it;
        typename unordered_map<ValueType, int>::iterator val_it;
        
        if ((abs(training_value) >= config_ptr->tracking_min && abs(training_value) <= config_ptr->tracking_max)){
            if (training_value != -1 && training_value != -2 && training_value != -4) {
                markov_table[training_key][training_value]++;
            }
        }

        key_it = markov_table.find(training_key);
        if ((abs(training_value) >= config_ptr->tracking_min && abs(training_value) <= config_ptr->tracking_max)) {
            if (training_value != -1 && training_value != -2 && training_value != -4) {
                val_it = key_it->second.find(training_value);
            }
        }

        // Prediction logic - identical behavior
        vector<ValueType> pf_topP = markov_prefetcher(prediction_key, key_it, val_it);
        
        prev_access_data = access_data;
        return pf_topP;
    }
    
    vector<ValueType> query_predictions(KeyType query_key) {
        vector<ValueType> top_predictions;
        
        auto it = markov_table.find(query_key);
        if (it != markov_table.end()) {
            auto &next_blocks = it->second;
            vector<pair<ValueType, int>> predictions(next_blocks.begin(), next_blocks.end());
            sort(predictions.begin(), predictions.end(),
                [](pair<ValueType, int> &a, pair<ValueType, int> &b) {
                    return a.second > b.second;
                });
            int total_count = accumulate(predictions.begin(), predictions.end(), 0,
                [](int sum, pair<ValueType, int>& p) {
                    return sum + p.second;
                });
            for (auto &prediction : predictions) {
                if ((static_cast<double>(prediction.second) * 100 / total_count) >= config_ptr->percent_threshold) {
                    top_predictions.push_back(prediction.first);
                } else {
                    break;
                }
            }
        }
        return top_predictions;
    }

private:
    unordered_map<KeyType, unordered_map<ValueType, int>> markov_table;
    using IteratorType = typename unordered_map<KeyType, unordered_map<ValueType, int>>::iterator;
    vector<typename unordered_map<ValueType, int>::iterator> markov_LRU;
    int markov_LRU_front;
    uint64_t pf_addr;
    const MT_Config* config_ptr;
    int MT_limit;

    typename unordered_map<ValueType, int>::iterator markov_evict_lru() {
        if (markov_LRU.empty()) return markov_table.begin()->second.end();
        typename unordered_map<ValueType, int>::iterator val_it = markov_LRU[0];
        for (int i = 1; i < markov_LRU_front && i < (int)markov_LRU.size(); i++) {
            markov_LRU[i - 1] = markov_LRU[i];
        }
        return val_it;
    }

    void markov_update_lru(int index) {
        if (index >= markov_LRU.size() || markov_LRU_front <= 0) return;
        auto tmpVal = markov_LRU[index];
        for (int i = index; i < markov_LRU_front - 1 && i < (int)markov_LRU.size() - 1; i++) {
            markov_LRU[i] = markov_LRU[i + 1];
        }
        if (markov_LRU_front > 0) {
            markov_LRU[markov_LRU_front - 1] = tmpVal;
        }
    }

    vector<ValueType> markov_prefetcher(KeyType lookup_key, IteratorType key_it, typename unordered_map<ValueType, int>::iterator val_it) {
        vector<ValueType> top_predictions;

        auto it = markov_table.find(lookup_key);
        if (it != markov_table.end()) {
            auto &next_blocks = it->second;
            vector<pair<ValueType, int>> predictions(next_blocks.begin(), next_blocks.end());
            sort(predictions.begin(), predictions.end(),
                      [](pair<ValueType, int> &a, pair<ValueType, int> &b) {
                          return a.second > b.second;
                      });
            int total_count = accumulate(predictions.begin(), predictions.end(), 0,
                [](int sum, pair<ValueType, int>& p) {
                    return sum + p.second;
                });
            for (auto &prediction : predictions) {
                if ((static_cast<double>(prediction.second) * 100 / total_count) >= config_ptr->percent_threshold) {
                    top_predictions.push_back(prediction.first);
                } else {
                    break;
                }
            }
        }
        
        auto lru_it = find(markov_LRU.begin(), markov_LRU.begin() + min(markov_LRU_front, (int)markov_LRU.size()), val_it);
        if (lru_it != markov_LRU.begin() + min(markov_LRU_front, (int)markov_LRU.size())) {
            int index = static_cast<int>(lru_it - markov_LRU.begin());
            markov_update_lru(index);
        } else {
            if (markov_LRU_front < MT_limit - 1) {
                if ((int)markov_LRU.size() <= markov_LRU_front) {
                    markov_LRU.resize(markov_LRU_front + 1);
                }
                markov_LRU[markov_LRU_front] = val_it;
                markov_LRU_front++;
            } else {
                auto toDel = markov_evict_lru();
                for (auto &outer_pair : markov_table) {
                    auto &inner_map = outer_pair.second;
                    for (auto it_inner = inner_map.begin(); it_inner != inner_map.end();) {
                        if (it_inner == toDel) {
                            it_inner = inner_map.erase(it_inner);
                            break;
                        } else {
                            ++it_inner;
                        }
                    }
                }
                for (auto it_outer = markov_table.begin(); it_outer != markov_table.end();) {
                    if (it_outer->second.empty()) {
                        it_outer = markov_table.erase(it_outer);
                    } else {
                        ++it_outer;
                    }
                }
                if (markov_LRU_front > 0 && markov_LRU.size() > markov_LRU_front - 1) {
                    markov_LRU[markov_LRU_front - 1] = val_it;
                }
            }
        }
        return top_predictions;
    }    
};

// IP tracker - EXACT as original
class IP_TRACKER {
  public:
    uint64_t ip;
    uint64_t last_cl_addr;
    int64_t last_stride;
    uint32_t lru;

    IP_TRACKER () {
        ip = 0;
        last_cl_addr = 0;
        last_stride = 0;
        lru = 0;
    };
};

