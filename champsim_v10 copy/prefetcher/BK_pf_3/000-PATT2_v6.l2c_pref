    // mt4_config.tracking_key="ip"; mt4_config.tracking_value="delta_block";
   
    // percentage is a entry count /total count of all entries ratio * 100 
    mt_ip_stride.lru_size=320; mt_ip_stride.tracking_max=63; mt_ip_stride.tracking_min=1; mt_ip_stride.percent_threshold=1; mt_ip_stride.prefetcher_id=0;
    mt_ip_stride.tracking_key="ip"; mt_ip_stride.tracking_value="stride_block";
