        //         }
        //     case IS_LLC:                                                // if 3 but !2 or 3 AND 2 but !1 or 3 AND 2 AND 1
        //         // LLC bypassed - check if L2C is NOT bypassed levels
        //         if (!(packet->bypassed_levels & ByPassBit_L2C)) {
