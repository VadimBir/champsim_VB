inline uint8_t CACHE::return_data_bypass_forward_destination(PACKET *packet){
    // DRAM RETURN BYPASS LOGIC <START> <START>

    if (packet->bypassed_levels == 0 ||
        !(packet->bypassed_levels & (1u << (cache_type - 4))))
    {
        // cout << "[" << NAME << "] " << (int)cache_type << " Norm Return: " << (packet->bypassed_levels & (1u << (cache_type - 4))) << endl;
#ifdef BYPASS_SANITY_CHECK
        if (packet->bypassed_levels & (1u << (cache_type - 4))) {
            std::cerr << "[" << NAME << "_ERROR] BYPASS LOGIC ERROR: cache_type: " << (int) cache_type
                      << " packet->bypassed_levels: " << (int) packet->bypassed_levels << std::endl;
            assert(0);
        }
#endif
        return BYPASS_DEST_NORMAL;   // NORMAL PATH
    } else {
        return BYPASS_DEST_CPU;
    }

        // uint8_t level_bit = 0;
        // switch (cache_type)  {
