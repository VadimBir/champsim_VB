//                 l1d->PROCESSED.add_queue(packet);
//             }
//             break;
//         }
//     }
//     return 1; // success
// }
void CACHE::return_data(PACKET *packet) {

    uint8_t bypass_destination = return_data_bypass_forward_destination(packet);


#ifdef BYPASS_SANITY_CHECK

    cout << "[" << NAME << "] cpu: "<< cpu << "cy: " << setw(9) << current_core_cycle[cpu] << " return_data bypass_destination: " << (int) bypass_destination << " bypassed_levels: " << (int) packet->bypassed_levels << endl;



    if (bypass_destination == BYPASS_DEST_NORMAL && (packet->bypassed_levels & (1<<(cache_type-4)))) {

        std::string err_msg =
            "RETURN DATA HAS BYPASS LVL BUT WE ARE DOING NO BYPASS \nLVL:[" + NAME + "] "
            "Bypass lvls:" + std::to_string(packet->bypassed_levels);
        std::fprintf(stderr, "%s\n", err_msg.c_str());
        assert(false);
    }
#endif
    if (bypass_destination == BYPASS_DEST_CPU) {
        if ((cache_type == IS_L1D) && (packet->type != PREFETCH))
        {
            if (PROCESSED.occupancy < PROCESSED.SIZE) {
                cout << "[L1D] BYPASS→PROCESSED: rob=" << packet->rob_index
                     << " lq=" << packet->lq_index
                     << " addr=" << hex << (packet->address<<LOG2_BLOCK_SIZE) << dec
                     << " bypassed=" << (int)packet->bypassed_levels << endl;
                PROCESSED.add_queue(packet);
                int mshr_check = check_mshr(packet);
                int rq_check = RQ.check_queue(packet);
                int wq_check = WQ.check_queue(packet);
                if (mshr_check != -1) {
                    MSHR.remove_queue(packet);
                    cout << "removed MSHR in bypassed return " << endl;
                }
                if (rq_check != -1) {
                    RQ.remove_queue(packet);
                    cout << "removed RQ in bypassed return " << endl;
                }

            } else {
                cout << "[L1D] BYPASS FAILED: PROCESSED FULL!" << endl;
                assert(false);
            }

        } else {
            upper_level_dcache[packet->cpu]->return_data(packet);
        }

#ifdef BYPASS_SANITY_CHECK
        int mshr_check = check_mshr(packet);
        int rq_check = RQ.check_queue(packet);
        int wq_check = WQ.check_queue(packet);

        if (mshr_check != -1) {
            cerr << "[" << NAME << "] BYPASS SANITY FAIL: MSHR entry exists for bypassed packet!" << endl;
            cerr << "  Address: " << hex << (packet->address << LOG2_BLOCK_SIZE) << dec << endl;
            cerr << "  MSHR index: " << mshr_check << endl;
            cerr << "  MSHR.returned: " << (int)MSHR.entry[mshr_check].returned << endl;
            cerr << "  packet->bypassed_levels: " << (int)packet->bypassed_levels << endl;
            assert(false);
        }

        if (rq_check != -1) {
            cerr << "[" << NAME << "] BYPASS SANITY FAIL: RQ entry exists for bypassed packet!" << endl;
            cerr << "  Address: " << hex << (packet->address << LOG2_BLOCK_SIZE) << dec << endl;
            cerr << "  RQ index: " << rq_check << endl;
            cerr << "  RQ.scheduled: " << (int)RQ.entry[rq_check].scheduled << endl;
            cerr << "  packet->bypassed_levels: " << (int)packet->bypassed_levels << endl;
            assert(false);
        }

        if (wq_check != -1) {
            cerr << "[" << NAME << "] BYPASS SANITY FAIL: WQ entry exists for bypassed packet!" << endl;
            cerr << "  Address: " << hex << (packet->address << LOG2_BLOCK_SIZE) << dec << endl;
            cerr << "  WQ index: " << wq_check << endl;
            cerr << "  packet->bypassed_levels: " << (int)packet->bypassed_levels << endl;
            assert(false);
        }
#endif

        int mshr_index = check_mshr(packet);
        if (mshr_index != -1 && MSHR.entry[mshr_index].bypassed_levels != 0) {

            assert(0&& "MSHR entry found during BYPASS to CPU - HOW DID IT REACH HERE???");
        }

        return;
    };

    int mshr_index = check_mshr(packet);

    MSHR.num_returned++;
    MSHR.entry[mshr_index].returned = COMPLETED;
    MSHR.entry[mshr_index].data = packet->data;
    MSHR.entry[mshr_index].bypassed_levels = packet->bypassed_levels;
    MSHR.entry[mshr_index].pf_metadata = packet->pf_metadata;

    if (MSHR.entry[mshr_index].event_cycle < current_core_cycle[packet->cpu])
        MSHR.entry[mshr_index].event_cycle = current_core_cycle[packet->cpu] + LATENCY;
    else
        MSHR.entry[mshr_index].event_cycle += LATENCY;

    update_fill_cycle();
}

