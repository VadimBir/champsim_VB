    bool isCounterAboveThreshold(int counter_value, int best_distance) {
        // Find max count for this distance to calculate ratio
        int max_count = 0;
        for (int d = 1; d <= MAX_DELTA; d++) {
            if (delta_counts[best_distance][d] > max_count) {
                max_count = delta_counts[best_distance][d];
            }
        }
        
        if (max_count == 0) return false;
        
        float ratio = (float)counter_value / (float) RESET_THRESHOLD;
        // cout << "isCounterAboveThreshold: counter_value=" << counter_value 
        //      << ", max_count=" << max_count << ", ratio=" << ratio 
        //      << ", count_thresh=" << count_thresh << " ratio >= count_thresh " << (ratio >= count_thresh) << endl;
        return ratio >= count_thresh;
    }
    int getMSHR_AdjustedTopD() {
        float fill_percentage = (float)mshr_occupancy / mshr_size * 100.0;
        
        int allowed_top_d;
        if (fill_percentage >= 100.0) {
            allowed_top_d = 1;
        } else {
            // For every 5% away from full, add 1 (starting from 2)
            allowed_top_d = 1 + (int)((100.0 - fill_percentage) / eachMSHRavailable_stepping);
        }
        
        // Cap at hard limit
        return min(allowed_top_d, TOP_D);
    }


    void print_delta_matrix() {
        cout << "Delta Count Matrix [distance][delta]:" << endl;
        
        // Header row - match distance column width
        cout << setw(7) << "Δ=>";
        for (int d = 1; d <= MAX_DELTA; d++) {
            cout << setw(4) << d;
        }
        cout << " | Sum" << endl;
        
        for (int i = 1; i < HIST_SIZE; i++) {
            cout << setw(2) << i;
            for (int d = 1; d <= MAX_DELTA; d++) {
                cout << setw(4) << delta_counts[i][d];
            }
            // calc sum for given i for all delta counts 
            int sum = 0;
            for (int d = 1; d <= MAX_DELTA; d++) {
                sum += delta_counts[i][d];
            }
            cout << " | " << setw(4) << sum;
            cout << endl;
        }
    }
    void print_incandescent_delta_matrix()    {
    didPrintTop = false;
    const float NAVY_TO_BLUE = 0.01f;
    const float BLUE_TO_GREEN = 0.5f;
    const float GREEN_TO_YELLOW = 0.75f;
    const float YELLOW_TO_RED = 0.97f;

    // cout << "Colored Delta Count Matrix [distance][delta]:" << endl;
    
    cout << "↓DIST↓\\→Δ→"<<endl;
    // for (int d = 1; d <= MAX_DELTA; d++) {
    //     cout << setw(2) << d;
    // }
    // cout << " | Sum" << endl;
    
    for (int i = 1; i < HIST_SIZE; i++) {
        cout << setw(2) << i;
        for (int d = 1; d <= MAX_DELTA; d++) {
            int val = delta_counts[i][d];
            float norm = min(1.0f, (float)val / RESET_THRESHOLD);
            
            int r, g, b;
            if (norm <= NAVY_TO_BLUE) {
                float t = norm / NAVY_TO_BLUE;
                r = 0; g = 0; b = (int)(128 + 127 * t);
            } else if (norm <= BLUE_TO_GREEN) {
                float t = (norm - NAVY_TO_BLUE) / (BLUE_TO_GREEN - NAVY_TO_BLUE);
                r = 0; g = (int)(255 * t); b = (int)(255 * (1 - t));
            } else if (norm <= GREEN_TO_YELLOW) {
                float t = (norm - BLUE_TO_GREEN) / (GREEN_TO_YELLOW - BLUE_TO_GREEN);
                r = (int)(255 * t); g = 255; b = 0;
            } else if (norm <= YELLOW_TO_RED) {
                float t = (norm - GREEN_TO_YELLOW) / (YELLOW_TO_RED - GREEN_TO_YELLOW);
                r = 255; g = (int)(255 * (1 - t)); b = 0;
            } else {
                r = 255; g = 0; b = 0;
            }
            cout << "\033[38;2;" << r << ";" << g << ";" << b << "m■\033[0m";
        }
        
        int sum = 0;
        for (int d = 1; d <= MAX_DELTA; d++) {
            sum += delta_counts[i][d];
        }
        cout << " | " << setw(5) << sum;
        
        

        int top[TOP_D] = {0}; // Initialize to 0
        for (int d = 1; d <= MAX_DELTA; d++) {
            int val = delta_counts[i][d];
            
            // Insert val into top array if it's larger
            for (int j = 0; j < TOP_D; j++) {
                if (val > top[j]) {
                    // Shift elements down
                    for (int k = TOP_D - 1; k > j; k--) {
                        top[k] = top[k-1];
                    }
                    top[j] = val;
                    break;
                }
            }
        }
        // Calculate average of top elements
        int top_sum = 0;
        int count = 0;
        for (int j = 0; j < TOP_D; j++) {
            if (top[j] > 0) {
                top_sum += top[j];
                count++;
            }
        }
        float avg_top = (count > 0) ? (float)top_sum / count : 0;
        // avg 
        cout << " | " << setw(4) << avg_top << endl;
    }
}
void print_colored_delta_matrix() {
    cout << "Colored Delta Count Matrix [distance][delta]:" << endl;
    
    cout << setw(7) << "Δ=>";
    for (int d = 1; d <= MAX_DELTA; d++) {
        cout << setw(4) << d;
    }
    cout << " | Sum" << endl;
    
    for (int i = 1; i < HIST_SIZE; i++) {
        cout << setw(2) << i;
        for (int d = 1; d <= MAX_DELTA; d++) {
            int val = delta_counts[i][d];
            float norm = (float)val / RESET_THRESHOLD;
            
            int r, g, b;
            if (norm <= 0.33f) {
                // Black to Blue
                float t = norm / 0.33f;
                r = 0; g = 0; b = (int)(255 * t);
            } else if (norm <= 0.66f) {
                // Blue to Yellow
                float t = (norm - 0.33f) / 0.33f;
                r = (int)(255 * t); g = (int)(255 * t); b = (int)(255 * (1-t));
            } else {
                // Yellow to Red
                float t = (norm - 0.66f) / 0.34f;
                r = 255; g = (int)(255 * (1-t)); b = 0;
            }
            
            cout << "\033[38;2;" << r << ";" << g << ";" << b << "m■\033[0m";
        }
        
        int sum = 0;
        for (int d = 1; d <= MAX_DELTA; d++) {
            sum += delta_counts[i][d];
        }
        cout << " | " << setw(4) << sum << endl;
    }
}
};

BlockHistory block_history;
uint64_t cnt = 0;

void CACHE::l1d_prefetcher_operate(uint64_t addr, uint64_t ip, uint8_t cache_hit, uint8_t type)
{
    if (cache_hit == 1) return;
    block_history.mshr_size = MSHR.SIZE;
    block_history.mshr_occupancy = MSHR.occupancy;
    uint64_t pf_addr = ((addr>>LOG2_BLOCK_SIZE)+1) << LOG2_BLOCK_SIZE;
    uint64_t block = addr >> LOG2_BLOCK_SIZE;
    // if (cache_hit == 0)
        block_history.add(block);
    
    for (int i=1; i<block_history.HIST_SIZE; i++) {
        if (std::find(retaining_dists.begin(), retaining_dists.end(), i) == retaining_dists.end()) 
            continue;
        int64_t deltaX = block_history.getLast(1) - block_history.getLast(i+1);
        if (deltaX >= 1 && deltaX <= 63) {
            block_history.delta_counts[i][deltaX]++;
        }
        block_history.check_and_reset_row(i);
    }

    if (cnt % printperiod == 0 && PRINT_TOP_DELTA_DISTANCE == 1) {
        cout << endl;
        // block_history.print();
        block_history.print_incandescent_delta_matrix();
        // block_history.print_delta_matrix();
    }

    // prefetching of top avg top 3 
    vector<int> best_deltas = block_history.getBestDeltas();
    uint64_t current_block = addr >> LOG2_BLOCK_SIZE;
    for (int delta : best_deltas) {
            uint64_t pf_addr = ((current_block + (delta)) << LOG2_BLOCK_SIZE);
            prefetch_line(ip, addr, pf_addr, FILL_L1, 0);
        // for (int degree = 1; degree < DEGREE; degree++) {
        //     // page check for next addr 
        //     if (((current_block + (delta * degree)) << LOG2_BLOCK_SIZE)>> LOG2_PAGE_SIZE != (addr >> LOG2_PAGE_SIZE)) {
        //         continue;
        //     }
        //     uint64_t pf_addr = ((current_block + (delta * degree)) << LOG2_BLOCK_SIZE);
        //     prefetch_line(ip, addr, pf_addr, FILL_L1, 0);
        // }
        // uint64_t pf_addr = ((current_block + delta) << LOG2_BLOCK_SIZE);
        // prefetch_line(ip, addr, pf_addr, FILL_L1, 0);
    }

    cnt++;
}

