// multiple delta bucket counters 
// every access L2 or L1 miss, cnt ++
// likewise, get top window and get top D delta with in a thresh BUT with count above top 2 window 
// adjust MSHR based on number of MSHR available where fill%/T% or TopD is max num Pf 

#include "cache.h"

#define PRINT_TOP_DELTA_DISTANCE 0
#define DEGREE 4

void CACHE::l1d_prefetcher_initialize() 
{
    cout << "CPU " << cpu << " L1D next line prefetcher" << endl;
}
int printperiod = 50000;
// vector of retaining dists with 1 2 4 dist 
#include <vector>
std::vector<int> retaining_dists = {1,4};
#include <algorithm>
struct BlockHistory {
    // num of distances to show and num of history blocks 
    const static int HIST_SIZE = 5;            
    // limit to a page
    const static int MAX_DELTA = 63;            
    // each delta bucket is cnt, upon reaching this, halve all counts in that row
    const static int RESET_THRESHOLD = 1073741823;     
    // calc AVG of top deltas in a row
    static constexpr int TOP_D = 8;
    // ratio of count filled before prefetching, e.g. TOP 1 is > thresh then Pf, then if TOP 2 is < thresh then skip                   
    float count_thresh = 0.45; 
    // % by which MSHR available allows more pf 
    float eachMSHRavailable_stepping = 25;
    uint64_t addrs[HIST_SIZE];
    int head = 0;
    int size = 0;
    int mshr_size;
    int mshr_occupancy;
    
    bool didPrintTop = false;
    // 2D array: [distance][delta] 
    int delta_counts[HIST_SIZE][MAX_DELTA + 1]; // +1 for 1-based indexing
    
    BlockHistory() {
        // Initialize delta_counts to 0
        for (int i = 0; i < HIST_SIZE; i++) {
            for (int j = 0; j <= MAX_DELTA; j++) {
                delta_counts[i][j] = 0;
            }
        }
        
    }
    
    void add(uint64_t block) {
        addrs[head] = block;
        head = (head + 1) % HIST_SIZE;
        if (size < HIST_SIZE) size++;
    }
    
    uint64_t getLast(int idx) {
        if (idx > size) return 0;
        int actual_idx = (head - idx + HIST_SIZE) % HIST_SIZE;
        return addrs[actual_idx];
    }
    
    void print() {
        for (int i = 0; i < size; i++) {
            int idx = (head + i) % HIST_SIZE;
            cout << addrs[idx] << " ";
        }
        cout << endl;
    }
    
    void check_and_reset_row(int distance) {
        for (int d = 1; d <= MAX_DELTA; d++) {
            if (delta_counts[distance][d] >= RESET_THRESHOLD) {
                // Reset only this distance row
                for (int dd = 1; dd <= MAX_DELTA; dd++) {
                    delta_counts[distance][dd] >>= 1; // Halve only this row
                }
                // cout << "RESET: Distance " << distance << " counts halved" << endl;
                return;
            }
        }
    }
    struct DistanceInfo {
        int distance;
        float avg_top;
        vector<pair<int,int>> sorted_deltas; // (delta, count) pairs sorted by count descending
        int next_index; // tracks which delta to consider next
        
        DistanceInfo(int d, float avg) : distance(d), avg_top(avg), next_index(0) {}
    };

    vector<int> getBestDeltas() {
        vector<DistanceInfo> distance_infos;
        
        // Step 1: Calculate averages and get sorted distances (like original)
        for (int i = 1; i < HIST_SIZE; i++) {
            int top[TOP_D] = {0};
            for (int d = 1; d <= MAX_DELTA; d++) {
                int val = delta_counts[i][d];
                for (int j = 0; j < TOP_D; j++) {
                    if (val > top[j]) {
                        for (int k = TOP_D - 1; k > j; k--) {
                            top[k] = top[k-1];
                        }
                        top[j] = val;
                        break;
                    }
                }
            }
            
            int top_sum = 0;
            int count = 0;
            for (int j = 0; j < TOP_D; j++) {
                if (top[j] > 0) {
                    top_sum += top[j];
                    count++;
                }
            }
            
            float avg_top = (count > 0) ? (float)top_sum / count : 0;
            if (avg_top > 0) {
                distance_infos.emplace_back(i, avg_top);
            }
        }
        
        // Sort distances by average (best distances first)
        sort(distance_infos.begin(), distance_infos.end(), [](const DistanceInfo& a, const DistanceInfo& b) {
            return a.avg_top > b.avg_top;
        });
        
        
        // Step 2: For each distance, get its sorted deltas
        for (auto& info : distance_infos) {
            for (int d = 1; d <= MAX_DELTA; d++) {
                if (delta_counts[info.distance][d] > 0 && 
                    isCounterAboveThreshold(delta_counts[info.distance][d], info.distance)) {
                    // cout << "cnt " << delta_counts[info.distance][d] << " isCounterAboveThreshold " << isCounterAboveThreshold(delta_counts[info.distance][d], info.distance) << endl;
                    info.sorted_deltas.push_back({d, delta_counts[info.distance][d]});
                }
            }
            
            // Sort this distance's deltas by count descending
            sort(info.sorted_deltas.begin(), info.sorted_deltas.end(), [](const auto& a, const auto& b) {
                return a.second > b.second;
            });
            
        }
        
        // Step 3: Step-by-step comparison as you described
        vector<int> selected_deltas;
        int adjusted_top_d = getMSHR_AdjustedTopD();
        
        for (int selection = 0; selection < adjusted_top_d; selection++) {
            int best_distance_idx = -1;
            int best_count = 0;
            
            // Find which distance has the highest count for its "next" delta
            for (int i = 0; i < distance_infos.size(); i++) {
                if (distance_infos[i].next_index < distance_infos[i].sorted_deltas.size()) {
                    int current_count = distance_infos[i].sorted_deltas[distance_infos[i].next_index].second;
                    if (current_count > best_count) {
                        best_count = current_count;
                        best_distance_idx = i;
                    }
                }
            }
            
            // If no more deltas available, break
            if (best_distance_idx == -1) break;
            
            // Select this delta and advance the pointer for this distance
            int selected_delta = distance_infos[best_distance_idx].sorted_deltas[distance_infos[best_distance_idx].next_index].first;
            // selected_deltas.push_back(selected_delta);
            if (std::find(selected_deltas.begin(), selected_deltas.end(), selected_delta) == selected_deltas.end()) {
                // degree add
                for (int degree = 1; degree <= DEGREE; degree++) {
                    // check if >63 
                    if (selected_delta * degree >= MAX_DELTA) continue;
                    if (adjusted_top_d <= 0) break;
                    selected_deltas.push_back(selected_delta); 
                    adjusted_top_d--;
                }
                // selected_deltas.push_back(selected_delta);
            }
            distance_infos[best_distance_idx].next_index++;
        }
        
        if (PRINT_TOP_DELTA_DISTANCE && !didPrintTop) {
            cout << "STEP-BY-STEP SELECTION: ";
            for (int i = 0; i < min((int)selected_deltas.size(), 5); i++) {
                // Find which distance this delta came from (for debugging)
                cout << "Δ" << selected_deltas[i] << " ";
            }
            cout << endl;
        }
        
        didPrintTop = true;
        return selected_deltas;
    }
